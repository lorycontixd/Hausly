{
  "expo": {
    "name": "Hausly",
    "slug": "hausly",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "scheme": "hausly",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hausly.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.hausly.app"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite"
    ]
  }
}

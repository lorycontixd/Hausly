# ==============================================================================
# Backend (apps/api)
# ==============================================================================

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hausly

# Firebase Auth
FIREBASE_PROJECT_ID=hausly-dev
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-sa.json

# Azure SignalR
SIGNALR_CONNECTION_STRING=Endpoint=https://hausly-dev-signalr.service.signalr.net;AccessKey=...;Version=1.0;

# Azure OpenAI (v3+ only, but wired from start)
AI_PROVIDER=azure_openai
AZURE_OPENAI_ENDPOINT=https://hausly-dev-openai.openai.azure.com/
AZURE_OPENAI_KEY=

# CORS
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# ==============================================================================
# Mobile (apps/mobile) — prefixed with EXPO_PUBLIC_ for client access
# ==============================================================================

EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=hausly-dev.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=hausly-dev
EXPO_PUBLIC_SIGNALR_URL=http://localhost:8000/hubs/household
